{
  "name": "wip-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@wip/browser-lab",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspace=@wip/browser-lab",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces --if-present"
  },
  "dependencies": {
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@types/react-window": "^2.0.0",
    "vitest": "^4.1.10",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.4"
  }
}